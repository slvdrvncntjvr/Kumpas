{
  "version": "baseline-v5",
  "random_seed": 42,
  "paths": {
    "labels_csv": "labels.csv",
    "train_csv": "train.csv",
    "test_csv": "test.csv",
    "video_base": "clips",
    "hand_landmarker_model": "models/hand_landmarker.task",
    "cache_dir": "cache/baseline-v5",
    "artifact_dir": "artifacts/baseline-v5"
  },
  "labels": [
    "YES",
    "NO",
    "DEAF",
    "THANK YOU",
    "SLOW",
    "DON\u2019T UNDERSTAND",
    "MARRIAGE LICENSE",
    "BARANGAY CLEARANCE",
    "CERTIFICATE OF INDIGENCY",
    "CERTIFICATE OF RESIDENCY",
    "CEDULA",
    "BLOTTER REPORT",
    "AYUDA",
    "NO_SIGN"
  ],
  "sequence_length": 40,
  "feature_count": 128,
  "temporal_crop": {
    "start_ratio": 0.15,
    "end_ratio": 0.85
  },
  "split_ratios": {
    "train": 0.7,
    "validation": 0.15,
    "test": 0.15
  },
  "hand_landmarker": {
    "num_hands": 2,
    "min_hand_detection_confidence": 0.4,
    "min_hand_presence_confidence": 0.4,
    "min_tracking_confidence": 0.4
  },
  "training": {
    "epochs": 100,
    "batch_size": 16,
    "learning_rate": 0.001,
    "early_stopping_patience": 15
  },
  "webcam_test": {
    "capture_seconds": 4.0,
    "width": 640,
    "height": 360,
    "confidence_threshold": 0.8,
    "minimum_hand_coverage": 0.25
  },
  "auto_capture": {
    "start_motion_threshold": 0.035,
    "stop_motion_threshold": 0.012,
    "start_frames": 3,
    "end_hold_seconds": 0.7,
    "minimum_sign_seconds": 0.8,
    "maximum_sign_seconds": 8.0,
    "pre_roll_seconds": 0.15,
    "post_roll_seconds": 0.15,
    "motion_smoothing": 0.4
  }
}
